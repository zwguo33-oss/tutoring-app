/* pages/index/index.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.welcome-section {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
}

.role-section {
  margin-top: 40rpx;
}

.role-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.role-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.role-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.role-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.features-section {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 40rpx;
  backdrop-filter: blur(10rpx);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 25rpx;
  text-align: center;
}

.feature-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx;
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #333;
}

.start-btn {
  margin-top: 50rpx;
  background: #fff;
  color: #667eea;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  padding: 35rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}
