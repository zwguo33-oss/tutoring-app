/* pages/teacher-dashboard/teacher-dashboard.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.greeting {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.date {
  font-size: 28rpx;
  opacity: 0.8;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  margin: 0 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.function-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.function-item {
  text-align: center;
  padding: 20rpx;
}

.function-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 10rpx;
}

.function-name {
  font-size: 24rpx;
  color: #666;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.booking-list {
  margin-top: 20rpx;
}

.booking-item {
  border: 2rpx solid #eee;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.booking-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.subject {
  font-size: 28rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.booking-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.booking-time text {
  display: block;
  margin-bottom: 8rpx;
}

.booking-actions {
  display: flex;
  gap: 20rpx;
}

.btn-accept, .btn-cancel {
  flex: 1;
  font-size: 26rpx;
  padding: 15rpx;
  border-radius: 10rpx;
}

.btn-accept {
  background: #07c160;
  color: #fff;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}
