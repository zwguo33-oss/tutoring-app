<!--pages/teacher-dashboard/teacher-dashboard.wxml-->
<view class="container">
  <!-- 顶部信息 -->
  <view class="header">
    <view class="welcome">
      <text class="greeting">你好，{{userInfo.nickname || '老师'}}</text>
      <text class="date">{{currentDate}}</text>
    </view>
  </view>
  
  <!-- 统计数据 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{stats.pendingCount}}</text>
      <text class="stat-label">待处理预约</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.completedCount}}</text>
      <text class="stat-label">已完成课程</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.rating}}</text>
      <text class="stat-label">平均评分</text>
    </view>
  </view>
  
  <!-- 功能入口 -->
  <view class="function-section">
    <text class="section-title">快捷操作</text>
    <view class="function-grid">
      <view class="function-item" bindtap="goToProfile">
        <text class="function-icon">📝</text>
        <text class="function-name">我的资料</text>
      </view>
      <view class="function-item" bindtap="goToSchedule">
        <text class="function-icon">📅</text>
        <text class="function-name">空闲时间</text>
      </view>
      <view class="function-item" bindtap="goToBookings">
        <text class="function-icon">📋</text>
        <text class="function-name">预约管理</text>
      </view>
      <view class="function-item" bindtap="goToCheckin">
        <text class="function-icon">📍</text>
        <text class="function-name">上课打卡</text>
      </view>
    </view>
  </view>
  
  <!-- 待处理预约 -->
  <view class="section">
    <text class="section-title">待处理预约</text>
    <view class="booking-list">
      <view 
        class="booking-item" 
        wx:for="{{pendingBookings}}" 
        wx:key="_id"
        bindtap="handleBooking"
        data-id="{{item._id}}"
      >
        <view class="booking-info">
          <text class="student-name">{{item.studentId.nickname}}</text>
          <text class="subject">{{item.subject}}</text>
        </view>
        <view class="booking-time">
          <text>📅 {{formatDate(item.appointmentTime)}}</text>
          <text>📍 {{item.location.address}}</text>
        </view>
        <view class="booking-actions">
          <button class="btn-accept" bindtap="acceptBooking" data-id="{{item._id}}">接受</button>
          <button class="btn-cancel" bindtap="cancelBooking" data-id="{{item._id}}">拒绝</button>
        </view>
      </view>
      
      <view class="empty-tip" wx:if="{{pendingBookings.length === 0}}">
        <text>暂无待处理预约</text>
      </view>
    </view>
  </view>
</view>
