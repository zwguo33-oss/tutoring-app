/* pages/checkin/checkin.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  color: #fff;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.booking-list, .checkin-record {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.booking-item {
  border: 2rpx solid #eee;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
}

.booking-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.subject {
  font-size: 28rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.booking-time {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.booking-time text {
  display: block;
  margin-bottom: 8rpx;
}

.distance-info {
  font-size: 24rpx;
  color: #ff9800;
  margin-bottom: 15rpx;
  padding: 10rpx;
  background: rgba(255, 152, 0, 0.1);
  border-radius: 8rpx;
}

.checkin-btn {
  width: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  padding: 20rpx;
}

.record-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.record-date {
  font-size: 28rpx;
  color: #333;
}

.record-status {
  font-size: 26rpx;
  color: #07c160;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}
