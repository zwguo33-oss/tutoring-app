/* pages/teacher-profile/teacher-profile.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.input, .textarea, .picker {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
}

.textarea {
  height: 200rpx;
}

.subject-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.subject-tag {
  padding: 12rpx 25rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.subject-tag.selected {
  background: #667eea;
  color: #fff;
}

.upload-item {
  margin-bottom: 25rpx;
}

.upload-box {
  padding: 30rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.upload-box[text*="✓"] {
  border-color: #07c160;
  color: #07c160;
  background: rgba(7, 193, 96, 0.05);
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}
